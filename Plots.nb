           RowBox[{"g", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "}"}], ";", 
         RowBox[{"i", "++"}]}]}], "]"}], ";", "\n", 
      RowBox[{"i", "=", "1"}], ";", "\n", 
      RowBox[{"While", "[", 
