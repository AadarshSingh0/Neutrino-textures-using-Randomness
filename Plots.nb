            RowBox[{
             RowBox[{"j", "<", 
              RowBox[{"K", "+", "1"}]}], ",", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"i", "==", "j"}], ",", 
                 RowBox[{
                  RowBox[{"mat", "[", 
                   RowBox[{"[", 
                    RowBox[{"i", ",", "j"}], "]"}], "]"}], "=", 
