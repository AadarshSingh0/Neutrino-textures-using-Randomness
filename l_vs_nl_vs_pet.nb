 RowBox[{
  RowBox[{"t", "=", "0.25"}], ";", 
  RowBox[{"c", "=", "2"}], ";", 
  RowBox[{"W", "=", "5"}], ";", 
  RowBox[{"K", "=", "12"}], ";", 
  RowBox[{"l", "=", 
   RowBox[{"t", "*", "c"}]}], ";", "\n", 
