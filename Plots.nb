                    RowBox[{"Abs", "[", 
                    RowBox[{"i", "-", "j"}], "]"}]}], "]"}]}]}]}]}], "]"}], 
               "}"}], ";", 
              RowBox[{"j", "++"}]}]}], "]"}]}], "}"}], ";", 
         RowBox[{"i", "++"}]}]}], "]"}], ";", "\n", 
      RowBox[{"mpet", "=", 
       RowBox[{"Normal", "[", "mat", "]"}]}], ";", "\n", 
