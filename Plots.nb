                    RowBox[{"i", "-", "j"}], "]"}]}], "]"}]}]}], ",", 
                RowBox[{
                 RowBox[{"Ox", "[", 
                  RowBox[{"[", 
                   RowBox[{
                    RowBox[{"j", "+", "K"}], ",", "i"}], "]"}], "]"}], " ", 
                 "=", " ", 
                 RowBox[{"l", "/", 
                  RowBox[{"Power", "[", 
                   RowBox[{"c", ",", 
                    RowBox[{"Abs", "[", 
                    RowBox[{"i", "-", "j"}], "]"}]}], "]"}]}]}]}], "}"}], ";", 
              RowBox[{"j", "++"}]}]}], "]"}]}], "}"}], ";", 
         RowBox[{"i", "++"}]}]}], "]"}], ";", "\n", 
      RowBox[{"i", "=", "1"}], ";", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"i", "<", 
         RowBox[{"K", "+", "1"}]}], ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"Ox", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", 
               RowBox[{"i", "+", "K"}]}], "]"}], "]"}], " ", "=", " ", 
            RowBox[{"g", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ",", 
           RowBox[{
            RowBox[{"Ox", "[", 
             RowBox[{"[", 
              RowBox[{
               RowBox[{"i", "+", "K"}], ",", "i"}], "]"}], "]"}], " ", "=", 
            " ", 
            RowBox[{"g", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}]}], " ", "}"}], ";", 
         RowBox[{"i", "++"}]}]}], "]"}], 
      RowBox[{"(*", 
       RowBox[{
       "Exponentially", " ", "decaying", " ", "hopping", " ", "terms"}], 
       "*)"}], ";", "\n", "Ox", ";", "\n", 
      RowBox[{"mnl", "=", 
       RowBox[{"Ox", "[", 
        RowBox[{"[", 
