Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Partition", " ", "the", " ", "data", " ", "into", " ", "chunks", " ", 
    "of", " ", "size", " ", "10"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"tempcn", "=", 
     RowBox[{"Partition", "[", 
      RowBox[{"cn", ",", "50"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tempan1", "=", 
     RowBox[{"Partition", "[", 
      RowBox[{"An1", ",", "50"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tempan", "=", 
     RowBox[{"Partition", "[", 
      RowBox[{"An", ",", "50"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tempan2", "=", 
     RowBox[{"Partition", "[", 
      RowBox[{"An2", ",", "50"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Calculate", " ", "the", " ", "median", " ", "of", " ", "each", " ", 
     "chunk"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"medcn", "=", 
     RowBox[{"Median", "/@", "tempcn"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"medan1", "=", 
     RowBox[{"Median", "/@", "tempan1"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"medan", "=", 
     RowBox[{"Median", "/@", "tempan"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"medan2", "=", 
     RowBox[{"Median", "/@", "tempan2"}]}], ";"}], "\[IndentingNewLine]", 
   "\n"}]}]], "Input",
 CellChangeTimes->{{3.918083965956461*^9, 3.918084126522418*^9}, {
  3.918084179371849*^9, 3.918084201618688*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"63aa7d48-8b83-469e-a3ca-503c7160ef82"],

