      RowBox[{"mat", " ", "=", " ", 
       RowBox[{"WeightedAdjacencyMatrix", "[", "p", "]"}]}], ";", "\n", 
      RowBox[{"i", "=", "1"}], ";", "\n", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"i", "<", 
